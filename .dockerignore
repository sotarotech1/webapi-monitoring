# Frontend (not part of the backend image)
monitoring-frontend/

# Dependencies (installed inside Docker)
vendor/
node_modules/

# Git
.git/
.gitignore
.gitattributes

# Dev tools
.editorconfig
phpunit.xml
.npmrc

# Environment files (injected at runtime)
.env
.env.*
!.env.example

# Storage contents (created at runtime)
storage/logs/*.log
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php

# Tests
tests/

# Docs
*.md
README*

# OS
.DS_Store
Thumbs.db
